# Focus spaces

alt - n : yabai -m space --focus next || yabai -m space --focus first
alt - p : yabai -m space --focus prev || yabai -m space --focus last

# Focus windows

alt - h : yabai -m window --focus west
alt - j : yabai -m window --focus south
alt - k : yabai -m window --focus north
alt - l : yabai -m window --focus east

# Move windows

ctrl + alt - h : yabai -m window --swap west
ctrl + alt - j : yabai -m window --swap south
ctrl + alt - k : yabai -m window --swap north
ctrl + alt - l : yabai -m window --swap east

ctrl + alt - n : yabai -m window --space next; yabai -m space --focus next
ctrl + alt - p : yabai -m window --space prev; yabai -m space --focus prev

# Resize windows

shift + alt - h : yabai -m window --resize left:-20:0; yabai -m window --resize right:-20:0
shift + alt - j : yabai -m window --resize bottom:0:20; yabai -m window --resize top:0:20
shift + alt - k : yabai -m window --resize top:0:-20; yabai -m window --resize bottom:0:-20
shift + alt - l : yabai -m window --resize right:20:0; yabai -m window --resize left:20:0

# Rotate windows clockwise (shift + alt + ])
shift + alt - 0x1E : yabai -m space --rotate 90

# Rotate windows counterclockwise (shift + alt + [)
shift + alt - 0x21 : yabai -m space --rotate 270

# Equalize size of windows (shift + alt + /)
shift + alt - 0x2C : yabai -m space --balance

# Toggle split vertically or horizontally (shift + alt + \)
shift + alt - 0x2A : yabai -m window --toggle split

# Toggle windows floating (shift + alt + ')
shift + alt - 0x27 : yabai -m window --toggle float; yabai -m window --grid 4:4:1:1:2:2

